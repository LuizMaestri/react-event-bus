{
  "name": "@luizmaestri/react-event-bus",
  "version": "1.0.1",
  "description": "Event Bus library for React",
  "type": "module",
  "main": "./dist/react-event-bus.umd.js",
  "module": "./dist/react-event-bus.es.js",
  "types": "./dist/index.d.ts",
